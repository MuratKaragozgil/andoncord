<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Precise terminal jump sends Apple events to iTerm2 / Terminal.app.
       The hardened runtime (required for notarisation) blocks Apple events
       unless the app declares this entitlement. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
